ENV=local
HTTP_PORT=8080
DATABASE_URL=postgres://bruska:bruska@localhost:5432/bruska?sslmode=disable

# Yandex Object Storage (S3)
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=webbackend
S3_PUBLIC_BASE_URL=https://storage.yandexcloud.net/webbackend
S3_USE_PATH_STYLE=true

KEY_ID=your-yandex-access-key-id
SECRET_KEY=your-yandex-secret-key

# Firebase Auth (Admin SDK)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_UIDS=comma,separated,admin,uids
